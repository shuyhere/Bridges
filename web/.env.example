# Bridges Web Frontend Environment Variables

# Public coordination/API URL used by the frontend.
# Example local loopback host: http://<COORDINATION_HOST>:17080
# Self-hosted remote: https://api.example.com
NEXT_PUBLIC_API_URL=http://<COORDINATION_HOST>:17080

# Optional human-facing coordination URL used in docs/examples.
# If omitted, NEXT_PUBLIC_API_URL is used.
NEXT_PUBLIC_COORDINATION_URL=http://<COORDINATION_HOST>:17080

# Optional example coordination URL shown in docs/UI snippets.
NEXT_PUBLIC_COORDINATION_EXAMPLE_URL=http://<COORDINATION_HOST>:17080

# Public Gitea URL used by dashboard links and iframe views.
# Example local loopback host: http://<GITEA_HOST>:3000
# Self-hosted remote: https://git.example.com
NEXT_PUBLIC_GITEA_URL=http://<GITEA_HOST>:3000
